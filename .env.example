TELEGRAM_BOT_TOKEN=

# AI Provider Configuration
# AI_PROVIDER: "openai" | "anthropic" | "google" (default: openai)
# AI_MODEL: model name, e.g. "gpt-4o", "claude-sonnet-4-20250514", "gemini-2.0-flash"
# AI_BASE_URL: (optional) custom endpoint for OpenAI-compatible APIs (Ollama, Groq, Together, etc.)
AI_PROVIDER=openai
AI_MODEL=gpt-4o
AI_API_KEY=
AI_BASE_URL=
MCP_SERVER_URL=http://localhost:3001/mcp
PORT=3001

# Access Control — Telegram Chat IDs
# ADMIN_CHAT_ID: Owner duy nhất, có quyền /allow và /block
# ALLOWED_CHAT_IDS: Danh sách chat IDs được phép dùng bot (comma-separated)
# Để trống = chỉ admin mới dùng được
ADMIN_CHAT_ID=
ALLOWED_CHAT_IDS=
