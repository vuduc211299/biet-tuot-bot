{
  "name": "news-finance-bot",
  "version": "1.0.0",
  "description": "VnExpress News + Financial Analysis MCP Chatbot via Telegram",
  "main": "./lib/src/index.js",
  "scripts": {
    "dev:http": "nodemon --exec tsx --inspect=9239 --signal SIGINT ./src/index.ts http",
    "dev:stdio": "nodemon --quiet --exec tsx --signal SIGINT ./src/index.ts stdio",
    "dev:bot": "nodemon --exec tsx --signal SIGINT ./src/bot-main.ts",
    "dev:inspector:http": "mcp-inspector --config .inspector.json --server mcptest_http",
    "dev:inspector:stdio": "mcp-inspector --config .inspector.json --server mcptest_stdio",
    "build": "tsc --build",
    "start:http": "node ./lib/src/index.js http",
    "start:stdio": "node ./lib/src/index.js stdio",
    "start:bot": "node ./lib/src/bot-main.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/openai": "^3.0.48",
    "@modelcontextprotocol/sdk": "^1.20.1",
    "ai": "^6.0.141",
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "grammy": "^1.41.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "0.17.2",
    "@types/cheerio": "^1.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
